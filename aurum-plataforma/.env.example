# ========================================
# 🗄️ Configuração para Banco de Dados LOCAL
# ========================================
# Copie este arquivo para .env antes de rodar o projeto:
#   copy .env.example .env
#
# Ajuste usuário/senha/porta conforme seu PostgreSQL local

# PostgreSQL local (padrão: postgres/postgres na porta 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aurum_plataforma"

# JWT para autenticação (opcional - há valor padrão no código)
# JWT_SECRET="sua-chave-secreta-local"

# ========================================
# 💳 AbacatePay — Integração de Pagamentos
# ========================================
# Chave de API do AbacatePay (obrigatória para o checkout)
# Dev (teste): abc_dev_...
# Prod (real): abc_live_...
ABACATEPAY_API_KEY="abc_dev_EwE2T5JwyHYAjwLLP4j4tFr5"

# Secret para validar webhooks (configure no dashboard do AbacatePay)
# Deixe em branco para desabilitar a validação em desenvolvimento
ABACATEPAY_WEBHOOK_SECRET=""

# URL base da aplicação (usada para montar returnUrl e completionUrl)
# Dev: http://localhost:3001  |  Prod: https://www.aurumnovaescola.com.br
NEXT_PUBLIC_BASE_URL="http://localhost:3001"
